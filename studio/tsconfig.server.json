{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "baseUrl": "..",
    "paths": {
      "@studio/shared/*": ["studio/shared/*"],
      "@forge/lib/*": ["scripts/forge/lib/*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "shared/**/*.ts",
    "../scripts/forge/lib/**/*.ts"
  ]
}
